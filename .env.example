# doubao2api 环境变量配置
# 复制此文件为 .env 并按需修改

# 服务端口
DOUBAO_PORT=9090

# 监听地址 (Docker 部署用 0.0.0.0)
DOUBAO_HOST=127.0.0.1

# API 密钥 (用于保护 /v1/* 端点，留空则不鉴权)
DOUBAO_API_KEY=

# Session 文件路径
DOUBAO_SESSION_FILE=.doubao_session.json

# 每分钟请求限制
DOUBAO_RPM_LIMIT=50

# 请求超时 (秒)
DOUBAO_TIMEOUT=180

# Session 保活间隔 (秒，默认 2 小时)
DOUBAO_KEEPALIVE_INTERVAL=7200

# 默认 Bot ID (7338286299411103781 = 扩展版/Expert)
DOUBAO_BOT_ID=7338286299411103781

# msToken (可选，留空最安全；假值会触发风控)
DOUBAO_MS_TOKEN=
